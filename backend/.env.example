# Server
PORT=4000
NODE_ENV=development

# CORS: comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# MongoDB connection string (MongoDB Atlas free tier or local mongod)
MONGODB_URI=mongodb://localhost:27017/bizscout

# httpbin monitoring
MONITOR_TARGET_URL=https://httpbin.org/anything
MONITOR_INTERVAL_MS=300000
# Run one ping immediately on startup (useful for demo). true/false
MONITOR_RUN_ON_START=true

# Anomaly threshold: a response is flagged when responseTime > factor * rolling average
ANOMALY_FACTOR=2

# Google Gemini (Option B). Without a key, LLM features degrade to rule-based fallbacks.
GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash
LLM_MAX_CALLS_PER_HOUR=20
LLM_CACHE_TTL_MS=600000

# Only used by the integration test (a disposable database — never production data)
# MONGO_TEST_URI=mongodb://127.0.0.1:27017/bizscout_test
